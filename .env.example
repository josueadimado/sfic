DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-secure-key
ALLOWED_HOSTS=127.0.0.1,localhost
# Public site URL (no trailing slash). In production use the host that works in the browser.
# If https://example.org times out but https://www.example.org works, either set SITE_BASE_URL to the www URL,
# or keep the apex here and set SITE_USE_WWW_FOR_HOST (see below).
SITE_BASE_URL=http://127.0.0.1:8000
# SITE_USE_WWW_FOR_HOST=setfreeinchristmission.org

# Minutes of no activity before the user must sign in again (dashboard + participant portal).
SESSION_IDLE_TIMEOUT_MINUTES=15
# Use True on production HTTPS so session cookies are only sent over secure connections.
# SESSION_COOKIE_SECURE=False

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@freedomintensive.local
